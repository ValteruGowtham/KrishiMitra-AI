# OpenAI
# Get key from: https://platform.openai.com/api-keys
# Key format: sk-proj-... or sk-...
# Models: gpt-3.5-turbo (cheapest), gpt-4o-mini (recommended), gpt-4o (expensive)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Sarvam AI (Indian language STT / TTS / Translation)
SARVAM_API_KEY=your_sarvam_api_key_here

# data.gov.in (AgMarkNet mandi price dataset — instant API key)
DATA_GOV_IN_API_KEY=your_data_gov_in_api_key_here
DATA_GOV_IN_RESOURCE_ID=your_resource_id_here

# IMD (India Meteorological Department)
IMD_API_KEY=your_imd_api_key_here

# Database
DATABASE_URL=sqlite:///./krishimitra.db

# App Config
APP_ENV=development
DEBUG=true
